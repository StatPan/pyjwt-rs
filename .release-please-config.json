{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "package-name": "pyjwt-rs",
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "generic",
          "path": "python/jwt_rs/__init__.py"
        },
        {
          "type": "generic",
          "path": "VERSIONING.md"
        }
      ],
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "refactor",
          "section": "Refactoring"
        },
        {
          "type": "build",
          "section": "Build System"
        },
        {
          "type": "ci",
          "section": "CI"
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": true
        },
        {
          "type": "chore",
          "section": "Miscellaneous",
          "hidden": true
        }
      ]
    }
  }
}
